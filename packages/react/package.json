{
  "name": "@arcnames/sdk-react",
  "version": "0.2.0",
  "description": "React hooks for ARC Name Service — useANSResolve, useANSReverse, useANSAvailability",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "arc",
    "ans",
    "react",
    "hooks",
    "name-service",
    "web3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NECOKIZZ/.arc.git",
    "directory": "packages/react"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@arcnames/sdk": ">=0.2.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@arcnames/sdk": "file:../sdk"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
